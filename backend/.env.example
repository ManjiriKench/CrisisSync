# ============================================================
# CrisisSync — Environment Variables
# Copy this file to .env and fill in real values to enable
# live integrations. Leave USE_MOCK_SERVICES=true to use mocks.
# ============================================================

# --- App ---
PORT=3001
NODE_ENV=development
JWT_SECRET=change-this-to-a-random-64-char-string
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8081

# --- Mock/Real toggle ---
# Set to false + fill keys below to switch to real APIs
USE_MOCK_SERVICES=true

# ============================================================
# FIREBASE
# HOW TO GET:
#  1. Go to https://console.firebase.google.com
#  2. Create project "crisissync"
#  3. Project Settings → Service Accounts → Generate new private key
#  4. Paste the JSON content (minified) into FIREBASE_SERVICE_ACCOUNT_KEY
#  5. Enable Realtime Database → copy the URL below
# ============================================================
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}
FIREBASE_DATABASE_URL=https://crisissync-default-rtdb.firebaseio.com
GOOGLE_CLOUD_PROJECT=crisissync

# ============================================================
# GEMINI AI
# HOW TO GET:
#  1. Go to https://aistudio.google.com/app/apikey
#  2. Click "Create API Key"
#  3. Copy the key below
# ============================================================
GEMINI_API_KEY=AIzaSy...

# ============================================================
# TWILIO (SMS + Voice auto-call to emergency services)
# HOW TO GET:
#  1. Sign up at https://www.twilio.com
#  2. Dashboard → Account SID + Auth Token are shown there
#  3. Buy a phone number → that's TWILIO_FROM_NUMBER
#  4. Set EMERGENCY_NUMBER to real local emergency line (e.g. 911 or 112)
# ============================================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1234567890
EMERGENCY_NUMBER=+19999999999
